# ClinicAI Environment Variables
# Copy file này thành .env và điền giá trị thật (KHÔNG commit .env)

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
# Service-role key — REQUIRED for the dashboard /settings/new-user
# admin-create-user flow (F3). Bypasses RLS — NEVER ship to the browser.
# Used server-side by app/api/admin/users/route.ts only.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres
# Separate DISPOSABLE database for DB tests. DB-touching tests (pytest -m db)
# ONLY connect here — never to prod DATABASE_URL. Leave unset → DB tests skip.
DATABASE_URL_TEST=postgresql+asyncpg://user:pass@host:5432/dbname_test

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# === RabbitMQ (T-P5-02) ===
RABBITMQ_URL=amqp://clinicai:clinicai_dev_pass@localhost:5672/clinicai
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=clinicai
RABBITMQ_PASSWORD=clinicai_dev_pass
RABBITMQ_VHOST=clinicai
RABBITMQ_EXCHANGE=events.topic
RABBITMQ_DLX=events.dlx

# App
APP_ENV=development
LOG_LEVEL=DEBUG

# Backend API key — gates every FastAPI route except /health, /health/db, /docs.
# Production deploys MUST set this; if unset the middleware logs a warning and
# allows every request through (dev-friendly fallback). See src/clinicai/api/auth.py.
BACKEND_API_KEY=<generate-a-long-random-string>

# Notion (Phase 1 sync source)
NOTION_API_KEY=<notion-integration-token>
# Root page of the cloned PK Notion workspace (no dashes is fine).
LINK_NOTION_PAGE_ID=<notion-root-page-id>
