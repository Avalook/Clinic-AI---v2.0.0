{
  "rabbit_version": "3.13.0",
  "vhosts": [
    {
      "name": "clinicai"
    }
  ],
  "exchanges": [
    {
      "name": "events.topic",
      "vhost": "clinicai",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "events.dlx",
      "vhost": "clinicai",
      "type": "fanout",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],
  "queues": [
    {
      "name": "events.audit",
      "vhost": "clinicai",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-message-ttl": 604800000,
        "x-dead-letter-exchange": "events.dlx"
      }
    },
    {
      "name": "events.dead_letter",
      "vhost": "clinicai",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "events.topic",
      "vhost": "clinicai",
      "destination": "events.audit",
      "destination_type": "queue",
      "routing_key": "#",
      "arguments": {}
    },
    {
      "source": "events.dlx",
      "vhost": "clinicai",
      "destination": "events.dead_letter",
      "destination_type": "queue",
      "routing_key": "",
      "arguments": {}
    }
  ]
}